{
  "name": "xiaoqing-ai-video-house",
  "version": "0.1.2",
  "description": "小晴的AI影视妙妙屋，本地 AI 视频制作无限画布桌面应用。",
  "author": "Xiaoqing",
  "repository": {
    "type": "git",
    "url": "https://github.com/eatguoking/xiaoqing-ai-video-house.git"
  },
  "homepage": "https://github.com/eatguoking/xiaoqing-ai-video-house#readme",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "desktop:dev": "electron electron/main.cjs",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:dist": "npm run build && electron-builder",
    "desktop:dist:cn": "set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/&& set ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/&& npm run build && electron-builder --win nsis --publish never",
    "desktop:release:github": "npm run build && electron-builder --win nsis --publish always",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:init": "node scripts/init-db.js",
    "db:clear": "node scripts/clear-db.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@xyflow/react": "^12.8.5",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@types/d3-color": "^3.1.3",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "prisma": "^6.19.3"
  },
  "build": {
    "appId": "com.xiaoqing.aivideohouse",
    "productName": "小晴的AI影视妙妙屋",
    "asar": false,
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "compression": "store",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      ".next/**/*",
      "!.next/cache/**/*",
      "build/**/*",
      "electron/**/*",
      "package.json",
      "next.config.ts",
      "public/**/*",
      "prisma/schema.prisma",
      "prisma/app-template.db"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "eatguoking",
        "repo": "xiaoqing-ai-video-house",
        "releaseType": "release"
      }
    ],
    "extraResources": [
      {
        "from": "node_modules/.prisma",
        "to": "app/node_modules/.prisma"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "xiaoqing-ai-video-house-setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "小晴的AI影视妙妙屋"
    }
  }
}
